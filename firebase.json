{
  "hosting": [
    {
      "site": "tahtipolku",
      "public": ".",
      "ignore": [
        "firebase.json",
        ".firebaserc",
        "**/.*",
        "**/node_modules/**",
        "*.md",
        "*.log",
        "404.html",
        "redirect/**"
      ]
    },
    {
      "site": "tahtipolku-bd9dc",
      "public": "redirect",
      "redirects": [
        {
          "source": "**",
          "destination": "https://tahtipolku.web.app",
          "type": 301
        }
      ]
    }
  ]
}
